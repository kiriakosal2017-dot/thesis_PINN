# Example environment file. Copy this to ".env" (or ".env.<vessel>") and fill in the
# values for your vessel. The application reads the active ".env" via config.py.
#
#   cp .env.example .env
#
# Values below are placeholders / illustrative defaults — replace them with your own.

# === Data ===
DATA_FILE_PATH=path/to/your_vessel_data.xlsx
TARGET_COLUMN=Shaft Power_TRQM
# Columns derived from the target are dropped to prevent leakage.
DROP_COLUMNS=TIME,NEW TIME,Shaft Torque_TRQM,Shaft Thrust_TRQM,Propeller-Shaft-Power,ME RPM_AMS
TIME_COLUMN=TIME

# === Data filtering (remove port/anchor rows) ===
MIN_POWER=1000
MIN_SPEED=4

# === Column names (match your dataset's headers) ===
SPEED_COLUMN=Speed-Through-Water
WAVE_HEIGHT_COLUMN=__WAVE_HEIGHT_NOT_AVAILABLE__
DRAFT_FORE_COLUMN=Fore draft_AMS
DRAFT_AFT_COLUMN=Aft draft_AMS
HEADING_COLUMN=Heading_BRG_GYRO
WAVE_DIRECTION_COLUMN=__WAVE_DIRECTION_NOT_AVAILABLE__

# === Ship physical constants (from hydrostatics; per vessel) ===
WATER_DENSITY=1025.0
WETTED_SURFACE_AREA=9950.0
APPENDAGE_WETTED_SURFACE=150.0
TRANSOM_AREA=50.0
CORRELATION_ALLOWANCE=0.00045
FORM_FACTOR=0.15
BASE_WAVE_RESISTANCE_COEFF=0.001
TRIM_EFFECT_COEFF=0.1
PROPULSIVE_EFFICIENCY=0.99
SHIP_LENGTH=225.5
KINEMATIC_VISCOSITY=1e-6
GRAVITY=9.81
TRANSOM_LENGTH=20.0
SHIP_DISPLACEMENT=82000000.0
ADDED_MASS_COEFF=0.1

# === Propeller constants (from propeller drawings; per vessel) ===
PROPELLER_DIAMETER=6.95
PROPELLER_BLADES=5
PROPELLER_PITCH_RATIO=0.7718
PROPELLER_AREA_RATIO=0.52

# === Sequence settings (PI-NODE temporal window) ===
SEQUENCE_LENGTH=10
MAX_TIME_GAP_SECONDS=3600

# === Recurrent-model defaults ===
LSTM_HIDDEN_SIZE=384
LSTM_NUM_LAYERS=2
LSTM_DROPOUT=0.2

# === Training defaults ===
TEST_SIZE=0.2
RANDOM_STATE=42
DEFAULT_EPOCHS_CV=50
DEFAULT_EPOCHS_FINAL=200
DEFAULT_OPTIMIZER=Adam
DEFAULT_LOSS_FUNCTION=MSE
WEIGHT_DECAY=1e-5
EARLY_STOPPING_PATIENCE=150
EARLY_STOPPING_MIN_DELTA=1e-4
